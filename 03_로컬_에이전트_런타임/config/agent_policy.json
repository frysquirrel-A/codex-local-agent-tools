      "stock",
      "broker",
      "trade",
      "buy order",
      "sell order"
    ],
    "spendingApproval": [
      "과금",
      "유료",
      "구독",
      "subscription",
      "upgrade",
      "license",
      "purchase",
      "buy",
      "결제",
      "구매",
      "pro 사용권",
      "월 요금",
