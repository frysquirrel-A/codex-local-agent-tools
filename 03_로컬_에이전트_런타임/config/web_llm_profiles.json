      "urlHints": [
        "gemini.google.com"
      ],
      "inputSelectors": [
        "div[role='textbox'][aria-label='Gemini 프롬프트 입력']",
        "div[role='textbox']"
      ],
      "sendSelectors": [
        "button.send-button",
        "button[aria-label*='전송']",
        "button[aria-label*='Send']"
      ]
    },
    "chatgpt": {
      "urlHints": [
        "chatgpt.com",
        "chat.openai.com"
      ],
      "inputSelectors": [
        "#prompt-textarea",
        "textarea[data-testid='prompt-textarea']",
        "textarea",
        "div[contenteditable='true'][data-testid='composer-root']",
        "div[contenteditable='true'][role='textbox']"
      ],
      "sendSelectors": [
        "button[data-testid='send-button']",
        "button[aria-label*='Send prompt']",
        "button[aria-label*='메시지 보내기']"
      ]
    }
